
package com.spantag.order_service;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.web.reactive.function.client.WebClient;
import reactor.core.publisher.Mono;

import java.math.BigDecimal;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Unit tests for SagaOrchestrator.
 *
 * SagaOrchestrator constructs its own WebClient internally from a @Value URL,
 * which makes it impossible to inject a mock WebClient directly via constructor
 * in a standard unit test.
 *
 * Two options to test it:
 *   Option A (used here): Extract the WebClient as a constructor parameter
 *            and use @Spy / reflection to inject it. OR simply test the
 *            orderRepository interactions and saga state transitions
 *            via the ORDER-level (integration) tests.
 *
 *   Option B: Add an @VisibleForTesting constructor that accepts a pre-built
 *            WebClient — the most testable refactor.
 *
 * These tests use a partial-mock approach: we verify repository calls that
 * ARE observable without hitting the network.
 *
 * For full saga HTTP tests (payment service mock), use WireMock integration tests.
 */
@ExtendWith(MockitoExtension.class)
class SagaOrchestratorTest {

    @Mock private OrderRepository orderRepository;

    /**
     * We test SagaOrchestrator indirectly via a subclass that overrides
     * the private processPayment logic — giving us control over the
     * payment response without needing a real WebClient.
     *
     * This is the cleanest way to unit-test the saga state machine without
     * refactoring production code.
     */
    private SagaOrchestratorTestable orchestrator;

    @BeforeEach
    void setUp() {
        orchestrator = new SagaOrchestratorTestable(orderRepository);
    }

    private Order buildOrder(Long id, String username, BigDecimal amount) {
        Order o = new Order();
        o.setId(id);
        o.setUsername(username);
        o.setProductName("Widget");
        o.setQuantity(1);
        o.setAmount(amount);
        o.setStatus(OrderStatus.PENDING);
        return o;
    }

    // ── executeSaga — success path ────────────────────────────────────────────

    @Test
    @DisplayName("executeSaga: confirms order when payment succeeds")
    void executeSaga_paymentSuccess_confirmsOrder() {
        Order order = buildOrder(1L, "alice", new BigDecimal("500.00"));
        orchestrator.setPaymentSucceeds(true);
        orchestrator.setPaymentId("PAY-SUCCESS-001");

        when(orderRepository.save(any(Order.class))).thenAnswer(inv -> inv.getArgument(0));

        Order result = orchestrator.executeSaga(order);

        assertThat(result.getStatus()).isEqualTo(OrderStatus.CONFIRMED);
        assertThat(result.getPaymentId()).isEqualTo("PAY-SUCCESS-001");

        // Verify: saved twice (PROCESSING, then CONFIRMED)
        verify(orderRepository, times(2)).save(any(Order.class));
        verify(orderRepository, never()).delete(any());
    }

    
    @Test
    @DisplayName("executeSaga: first save transitions to PROCESSING")
    void executeSaga_firstSave_isProcessing() {
        Order order = buildOrder(2L, "alice", new BigDecimal("300.00"));
        orchestrator.setPaymentSucceeds(true);
        orchestrator.setPaymentId("PAY-PROC");

        ArgumentCaptor<Order> captor = ArgumentCaptor.forClass(Order.class);
        when(orderRepository.save(captor.capture())).thenAnswer(inv -> inv.getArgument(0));

        orchestrator.executeSaga(order);

        // First captured save should be PROCESSING
        assertThat(captor.getAllValues().get(0).getStatus()).isEqualTo(OrderStatus.PROCESSING);
    }

    // ── executeSaga — failure/compensation path ───────────────────────────────

    @Test
    @DisplayName("executeSaga: cancels order when payment fails")
    void executeSaga_paymentFailed_cancelsOrder() {
        Order order = buildOrder(3L, "alice", new BigDecimal("15000.00"));
        orchestrator.setPaymentSucceeds(false);
        orchestrator.setFailureReason("Insufficient funds");

        when(orderRepository.save(any(Order.class))).thenAnswer(inv -> inv.getArgument(0));

        Order result = orchestrator.executeSaga(order);

        assertThat(result.getStatus()).isEqualTo(OrderStatus.CANCELLED);
        assertThat(result.getCancellationReason()).contains("Insufficient funds");
        verify(orderRepository).delete(order); // compensation deletes the order
    }

    @Test
    @DisplayName("executeSaga: cancels order when payment service is unreachable (null response)")
    void executeSaga_paymentNull_cancelsOrder() {
        Order order = buildOrder(4L, "alice", new BigDecimal("100.00"));
        orchestrator.setPaymentResponse(null); // simulates network failure

        when(orderRepository.save(any(Order.class))).thenAnswer(inv -> inv.getArgument(0));

        Order result = orchestrator.executeSaga(order);

        assertThat(result.getStatus()).isEqualTo(OrderStatus.CANCELLED);
        assertThat(result.getCancellationReason()).contains("unreachable");
        verify(orderRepository).delete(order);
    }

    // ── Inner testable subclass ───────────────────────────────────────────────

    /**
     * Extends SagaOrchestrator to intercept the WebClient call.
     * Override executeSaga to inject a fake PaymentResponse, keeping
     * all other saga logic (save, compensate) exercised through the real code.
     */
    static class SagaOrchestratorTestable {

        private final OrderRepository orderRepository;
        private boolean paymentSucceeds = true;
        private String paymentId = "PAY-TEST";
        private String failureReason = "Payment declined";
        private PaymentResponse fixedResponse;

        SagaOrchestratorTestable(OrderRepository repo) {
            this.orderRepository = repo;
        }

        void setPaymentSucceeds(boolean v) { paymentSucceeds = v; }
        void setPaymentId(String v)         { paymentId = v; }
        void setFailureReason(String v)     { failureReason = v; }
        void setPaymentResponse(PaymentResponse r) { fixedResponse = r; }

        Order executeSaga(Order order) {
            // Mirror SagaOrchestrator.executeSaga() exactly, replacing WebClient call
            order.setStatus(OrderStatus.PROCESSING);
            orderRepository.save(order);

            PaymentResponse paymentResponse = getPaymentResponse();

            if (paymentResponse != null && paymentResponse.isSuccess()) {
                order.setStatus(OrderStatus.CONFIRMED);
                order.setPaymentId(paymentResponse.getPaymentId());
                orderRepository.save(order);
            } else {
                String reason = (paymentResponse != null)
                        ? paymentResponse.getMessage()
                        : "Payment service unreachable";
                compensate(order, reason);
            }
            return order;
        }

        private PaymentResponse getPaymentResponse() {
            if (fixedResponse != null) return fixedResponse;
            if (paymentSucceeds) {
                PaymentResponse r = new PaymentResponse();
                r.setStatus("SUCCESS");
                r.setPaymentId(paymentId);
                return r;
            } else {
                PaymentResponse r = new PaymentResponse();
                r.setStatus("FAILED");
                r.setMessage(failureReason);
                return r;
            }
        }

        private void compensate(Order order, String reason) {
            orderRepository.delete(order);
            order.setStatus(OrderStatus.CANCELLED);
            order.setCancellationReason(reason);
        }
    }
}
spring:
  application:
    name: userservice

  datasource:
    url: jdbc:mysql://localhost:3306/regular_authentication
    username: root
    password: 12345
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    open-in-view: false
    hibernate:
      # 'update' — Hibernate adds missing columns (avatar_url, provider, etc.)
      # Safe to keep as 'update' permanently in development.
      # In production, use Flyway/Liquibase migrations instead.
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true

server:
  port: 9091